# User-Agent sent on every HTTP request to Wikimedia servers.
# Wikimedia policy requires: ToolName/version (URL; contact-email)
# See: https://www.mediawiki.org/wiki/API:Etiquette#The_User-Agent_header
# The trailing "python-httpx/x.x" identifies the HTTP library actually used.
WIKIMEDIA_USER_AGENT=YourBotName/1.0 (https://your-project-url.example.com/; your-email@example.com) python-httpx

# --- Dump source (wikidata_dump_etl.py / run_etl.sh) ---
#
# Three valid combinations:
#
#   1. DUMP_URL only
#      The dump is streamed from HTTP for each of the 3 passes.
#      Nothing is written to disk. Requires network for every pass.
#
#   2. DUMP_FILE only (file must already exist on the shared volume)
#      The local .bz2 file is read for each of the 3 passes.
#      The file is never fully decompressed; it is streamed chunk by chunk.
#
#   3. DUMP_FILE + DUMP_URL
#      If DUMP_FILE does not exist yet, it is downloaded from DUMP_URL first.
#      All 3 passes then read from the local file (saving bandwidth).
#      If DUMP_FILE already exists, DUMP_URL is ignored.
#
# In all cases the .bz2 is decompressed in streaming chunks; the full
# decompressed content is never stored on disk.

# DUMP_URL=https://dumps.wikimedia.org/wikidatawiki/entities/latest-all.json.bz2
# DUMP_FILE=/shared/latest-all.json.bz2

# --- MariaDB connection (used by the staging-load script after ETL) ---
# MARIADB_HOST=127.0.0.1
# MARIADB_PORT=3306
# MARIADB_USER=wikidata_user
# MARIADB_PASSWORD=secret
# MARIADB_DATABASE=wikidata_db
# MARIADB_IMPORT_BATCH_ID=weekly_2026_03_13
